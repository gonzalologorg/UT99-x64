<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-sdk android:minSdkVersion="16" />

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- Needed on very old Android versions when pushing game data to external storage. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- Multiplayer / LAN / listen-server sockets. Required before IpDrv can bind UDP/TCP. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <application
        android:allowBackup="false"
        android:extractNativeLibs="true"
        android:hardwareAccelerated="false"
        android:hasCode="true"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/ouya_icon"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <meta-data
            android:name="tv.ouya.icon"
            android:resource="@drawable/ouya_icon" />

        <activity
            android:name=".MainActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|touchscreen|uiMode"
            android:exported="true"
            android:immersive="true"
            android:launchMode="singleTop"
            android:maxAspectRatio="10.0"
            android:resizeableActivity="false"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
                <category android:name="tv.ouya.intent.category.GAME" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GameActivity"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|touchscreen|uiMode"
            android:exported="false"
            android:finishOnTaskLaunch="true"
            android:hardwareAccelerated="false"
            android:immersive="true"
            android:launchMode="standard"
            android:maxAspectRatio="10.0"
            android:process=":game"
            android:resizeableActivity="false"
            android:screenOrientation="landscape" />

    </application>
</manifest>
